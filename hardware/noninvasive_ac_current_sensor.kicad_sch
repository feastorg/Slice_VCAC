	(text "-ZMCT103C: 0 to 10A maps 0 to 10mA w/ \n  100ohm burden resistor results in 0 to 1000mV\n-ZMCT103D: results in 0 to 375mV.\n-SCT-013-000: 0 to 100A maps to 0 to 5mA w/ \n  100ohm burden resistor results in 0 to 500mV\n-SCT-013-xxx: (except xxx=000) result in 0 to 1000mV"
		(exclude_from_sim no)
		(at 34.798 66.802 0)
		(effects
			(font
				(size 0.889 0.889)
			)
			(justify left)
		)
		(uuid "036a6a96-b95f-4ca4-977b-4b1f84ee3536")
	)
