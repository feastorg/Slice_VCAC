	)
	(text "fc_l = 1/(2*PI*10kOhm*0.47uF) \nfc_l = 1/[2*PI*10*(10^3)0.47*(10^-6)] \nfc_l = 33.86Hz"
		(exclude_from_sim no)
		(at 114.808 68.834 0)
		(effects
			(font
				(size 1.016 1.016)
				(thickness 0.0794)
