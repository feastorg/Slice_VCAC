	)
	(text "-ZMCT103C is a N.I.S.C. current transformer 0-10A with 5mA @ 5A (1:1000 ratio).\n-ZMCT103D is a N.I.S.C. current transformer 0-10A with internal resistance of \n150R and 2.5mA @ 5A (1:2000 ratio) resulting in 375mV.\n-SCT-013-xxx is a family of N.I.S.C. current transformer from 5A to 100A max.\n	- xxx signifies its maximum current i.e. 010 is 10A and 000 is 100A\n	- xxx=000 is a current type output from 0-5mA w/ built-in TVS diode\n	- all others are voltage type output from  0-1V\n*N.I.S.C. = non-invasive split-core"
		(exclude_from_sim no)
		(at 35.052 55.88 0)
		(effects
			(font
				(size 0.889 0.889)
			)
			(justify left)
		)
		(uuid "8fbbb9f5-5bcb-4648-b80b-a6b342a61e47")
	)
