	)
	(text "fc_l = 1/(2*PI*10kOhm*0.47uF) \nfc_l = 1/[2*PI*10*(10^3)0.47*(10^-6)] \nfc_l = 33.86Hz"
		(exclude_from_sim no)
		(at 178.562 68.834 0)
		(effects
			(font
				(size 1.016 1.016)
				(thickness 0.0794)
			)
			(justify right)
		)
		(uuid "528d28e1-f4a5-4bde-b58f-10356a4cf019")
	)
	(text "AC_LINE_2"
		(exclude_from_sim no)
		(at 230.124 91.44 0)
		(effects
